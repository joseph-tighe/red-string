{
  "manifest_version": 3,
  "name": "Red String",
  "version": "0.0.1",
  "description": "A research helper",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "123e4567-e89b-12d3-a456-426614174000@redstring",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": [],
        "uses_without_permission": [
          "extension_settings",
          "extension_storage"
        ],
        "uses_with_permission": [],
        "hosts": []
      }
    }
  }
}
